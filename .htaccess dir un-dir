RewriteEngine On

# ===============================
# REMOVE .php FROM URL (INTERNAL)
# ===============================

# Jika file .php ada, tampilkan tanpa .php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# ===============================
# OPTIONAL: BLOCK DIRECT .php
# ===============================
# Uncomment jika ingin paksa tanpa .php
#RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?]
#RewriteRule ^ %1 [R=301,L]
